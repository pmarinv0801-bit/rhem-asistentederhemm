}

.sr-checkbox-indicator:hover {
    border-color: var(--smtc-ctrl-choice-base-stroke-hover, var(--smtc-foreground-ctrl-neutral-secondary-rest));
    background: var(--smtc-ctrl-choice-base-background-hover, var(--smtc-background-ctrl-outline-hover, var(--smtc-null-color)));
}

.sr-checkbox-indicator:active {
    border-color: var(--smtc-ctrl-choice-base-stroke-pressed, var(--smtc-foreground-ctrl-neutral-secondary-rest));
    background: var(--smtc-ctrl-choice-base-background-pressed, var(--smtc-background-ctrl-outline-pressed, var(--smtc-null-color)));
}

/* Checked state */
.sr-checkbox-input:checked + .sr-checkbox-indicator {
    background: var(--smtc-background-ctrl-active-brand-rest, var(--smtc-background-ctrl-brand-rest));
    border-color: transparent;
}

.sr-checkbox-input:checked + .sr-checkbox-indicator:hover {
    background: var(--smtc-background-ctrl-active-brand-hover, var(--smtc-background-ctrl-brand-hover));
}


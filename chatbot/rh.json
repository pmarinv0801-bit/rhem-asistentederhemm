    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
}

/* Chevron area */

.sr-dropdown-chevron-wrap {
    display: flex;
    flex-shrink: 0;
    flex-grow: 1;
    align-items: center;
    justify-content: flex-end;
    column-gap: 0.5rem;
    min-height: 26px;
}

.sr-dropdown-chevron {
    width: 1.5rem;
    height: 1.5rem;
    transition: transform 150ms;
}

.sr-dropdown-chevron-open {
    transform: rotate(180deg);
}

/* Menu / listbox — acrylic material matching core listbox */

.sr-dropdown-menu {
    display: flex;
    flex-direction: column;
    background-color: var(--smtc-material-acrylic-default-solid, var(--smtc-background-layer-primary-solid));
    border-radius: var(--smtc-corner-flyout-rest);
    border: none;
    box-shadow: var(--smtc-shadow-flyout-key), var(--smtc-shadow-flyout-ambient), var(--mai-smtc-shadow-flyout-contour);
    box-sizing: border-box;
    margin: 0;
    min-width: 160px;
    padding: var(--smtc-padding-flyout-default, var(--smtc-padding-content-align-outdent-text-on-subtle));
    row-gap: var(--smtc-gap-between-list-item, var(--smtc-gap-between-content-xx-small));
    backdrop-filter: blur(var(--smtc-material-acrylic-blur));
    background: linear-gradient(0deg, var(--smtc-material-acrylic-default-solid, var(--smtc-background-layer-primary-solid)) 0%, var(--smtc-material-acrylic-default-solid, var(--smtc-background-layer-primary-solid)) 100%),
                linear-gradient(0deg, var(--smtc-material-acrylic-default-lum-blend, var(--smtc-background-layer-primary-solid)) 0%, var(--smtc-material-acrylic-default-lum-blend, var(--smtc-background-layer-primary-solid)) 100%),
                linear-gradient(0deg, var(--smtc-material-acrylic-default-color-blend, var(--smtc-background-layer-primary-solid)) 0%, var(--smtc-material-acrylic-default-color-blend, var(--smtc-background-layer-primary-solid)) 100%),
                var(--mai-smtc-background-flyout-saturation-blend, var(--smtc-null-color));
    background-blend-mode: normal, luminosity, color, saturation;
    width: auto;
}

.sr-dropdown-menu:not(:popover-open) {
    display: none;
}

.sr-dropdown-menu[popover] {
    inset: unset;
    overflow: auto;
}

@supports (anchor-name: --anchor) {
    .sr-dropdown-menu[popover] {
        position: absolute;
        margin-block-start: 0;
        max-height: var(--listbox-max-height, calc(50vh - anchor-size(self-block)));
        min-width: anchor-size(width);
        position-area: block-end span-inline-end;
        position-try-fallbacks: flip-inline, flip-block, block-start;
    }

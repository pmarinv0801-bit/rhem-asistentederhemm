.sr-badge {
    display: inline-flex;
    flex: none;
    font-family: var(--smtc-text-style-default-regular-font-family);
    font-weight: var(--smtc-text-style-default-regular-weight);
    font-size: var(--smtc-text-ramp-metadata-font-size, var(--smtc-text-global-caption1-font-size));
    line-height: var(--smtc-text-ramp-metadata-line-height, var(--smtc-text-global-caption1-line-height));
    border-radius: var(--smtc-ctrl-badge-corner);
    padding-block: var(--smtc-ctrl-badge-text-padding-top) var(--smtc-ctrl-badge-text-padding-bottom, var(--smtc-ctrl-badge-text-padding-top));
    padding-inline: calc(var(--smtc-ctrl-badge-padding) + var(--smtc-padding-ctrl-text-side));
    height: var(--smtc-ctrl-badge-size);
    gap: calc(var(--smtc-ctrl-badge-gap) + var(--smtc-padding-ctrl-text-side));
    box-sizing: border-box;
    align-items: center;
}

.sr-badge-pill {
    border-radius: var(--smtc-corner-circular);
}

/* Size variants */

.sr-badge-size-sm {
    height: var(--smtc-ctrl-badge-sm-size);
    font-size: var(--smtc-text-ramp-sm-item-body-font-size, var(--smtc-text-global-caption1-font-size));
    line-height: var(--smtc-text-ramp-sm-item-body-line-height, var(--smtc-text-global-caption1-line-height));
    padding-inline: var(--smtc-ctrl-badge-padding);
}

.sr-badge-size-md {
    height: var(--smtc-ctrl-badge-size);
    font-size: var(--smtc-text-ramp-sm-item-body-font-size, var(--smtc-text-global-caption1-font-size));
    line-height: var(--smtc-text-ramp-sm-item-body-line-height, var(--smtc-text-global-caption1-line-height));
    padding-inline: var(--smtc-ctrl-badge-lg-padding);
}

.sr-badge-size-lg {
    height: var(--smtc-ctrl-badge-size);
    font-size: var(--smtc-text-ramp-sm-item-body-font-size, var(--smtc-text-global-caption1-font-size));
    line-height: var(--smtc-text-ramp-sm-item-body-line-height, var(--smtc-text-global-caption1-line-height));
    padding-inline: var(--smtc-ctrl-badge-lg-padding);
}


/* Color × variant combinations */

.sr-badge-secondary-soft {
    background: var(--smtc-status-informative-tint-background);
    color: var(--smtc-status-informative-tint-foreground);
}

.sr-badge-secondary-solid {
    background: var(--mai-smtc-background-ctrl-on-image-rest);
    color: var(--mai-smtc-foreground-ctrl-on-image, var(--smtc-foreground-ctrl-on-brand-rest));
}

.sr-badge-secondary-outline {
    background: transparent;
    color: var(--smtc-status-informative-tint-foreground);
    border: 1px solid var(--smtc-status-informative-tint-background);
}

.sr-badge-success-soft {
    background: var(--smtc-status-success-tint-background);
    color: var(--smtc-status-success-tint-foreground);
}

.sr-badge-success-solid {
    background: var(--smtc-status-success-background);
    color: var(--smtc-status-success-foreground, var(--smtc-foreground-ctrl-on-brand-rest));
}

.sr-badge-success-outline {
    background: transparent;
    color: var(--smtc-status-success-tint-foreground);
    border: 1px solid var(--smtc-status-success-tint-stroke);
}

.sr-badge-danger-soft {
    background: var(--smtc-status-danger-tint-background);
    color: var(--smtc-status-danger-tint-foreground);
}

.sr-badge-danger-solid {
    background: var(--smtc-status-danger-background);
    color: var(--smtc-status-danger-foreground, var(--smtc-foreground-ctrl-on-brand-rest));
}

.sr-badge-danger-outline {
    background: transparent;
    color: var(--smtc-status-danger-tint-foreground);
    border: 1px solid var(--smtc-status-danger-tint-stroke);
}

.sr-badge-warning-soft {
    background: var(--smtc-status-warning-tint-background);
    color: var(--smtc-status-warning-tint-foreground);
}

.sr-badge-warning-solid {
    background: var(--smtc-status-warning-background);
    color: var(--smtc-status-warning-foreground, var(--smtc-foreground-ctrl-on-brand-rest));
}

.sr-badge-warning-outline {
    background: transparent;
    color: var(--smtc-status-warning-tint-foreground);
    border: 1px solid var(--smtc-status-warning-tint-stroke);
}

/* Font weight */

.sr-badge-font-regular {
    font-weight: 400;
}

.sr-badge-font-light {
    font-weight: 450;
    font-variation-settings: "wght" 450;
}

/* Uppercase modifier */

.sr-badge-uppercase {
    text-transform: uppercase;
}
</style><style data-sr-styles="genui-resolvers">
:root {
    --color-accent-400: #3b82f6;
    --color-accent-350: #60a5fa;
    --color-accent-300: #93c5fd;
    --color-background-200: #ccc6;
    --color-genui-blue-600: #1e40af;
    --color-stroke-300: #e5e7eb;
    --color-black: #000;
    --_squircle-modifier: 1;
}

 @supports (corner-shape: squircle) {
      :root {
        --_squircle-modifier: 1.8;
        }
    }


.genui-box {
    --_squircle-modifier: 1;
}

@supports (corner-shape: squircle) {
    .genui-box {
        --_squircle-modifier: 1.8;
    }
}

/* Base */

.genui-box {
    position: relative;
    box-sizing: border-box;
}

/* Display & overflow */

.flex {
    display: flex;
}

.contents {
    display: contents;
}

.overflow-hidden {
    overflow: hidden;
}

.overflow-y-auto {
    overflow-y: auto;
}

/* Flex direction */

.flex-row {
    flex-direction: row;
}

.flex-col {
    flex-direction: column;
}

/* Flex alignment */

.items-start {
    align-items: flex-start;
}

.items-center {
    align-items: center;
}

.items-end {
    align-items: flex-end;
}

.items-baseline {
    align-items: baseline;
}

.items-stretch {
    align-items: stretch;
}

/* Flex justify */

.justify-start {
    justify-content: flex-start;
}

.justify-center {
    justify-content: center;
}

.justify-end {
    justify-content: flex-end;
}

.justify-between {
    justify-content: space-between;
}

.justify-around {
    justify-content: space-around;
}

.justify-evenly {
    justify-content: space-evenly;
}

.justify-stretch {
    justify-content: stretch;
}

/* Flex wrap */

.flex-nowrap {
    flex-wrap: nowrap;
}

.flex-wrap {
    flex-wrap: wrap;
}

.flex-wrap-reverse {
    flex-wrap: wrap-reverse;
}

/* Sizing */

.size-full {
    width: 100%;
    height: 100%;
}

.size-3 {
    width: 12px;
    height: 12px;
}

.size-4 {
    width: 16px;
    height: 16px;
}

.size-5 {
    width: 20px;
    height: 20px;
}

.size-6 {
    width: 24px;
    height: 24px;
}

.size-7 {
    width: 28px;
    height: 28px;
}

.size-8 {
    width: 32px;
    height: 32px;
}

.size-12 {
    width: 48px;
    height: 48px;
}

/* Border radius */


    font-size: var(--smtc-text-ramp-sm-item-body-font-size, var(--smtc-text-global-caption1-font-size));
}

.genui-lv-toggle:hover {
    background: var(--smtc-background-ctrl-neutral-hover);
}

.genui-lv-toggle-wrapper {
    display: flex;
    justify-content: flex-start;
}

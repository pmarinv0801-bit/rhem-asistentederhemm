.sr-select-wrapper-fit {
    width: fit-content;
}

/* Trigger overrides */

.sr-select-trigger {
    appearance: none;
    background-color: var(--smtc-ctrl-input-background-rest, var(--smtc-background-ctrl-neutral-rest));
    border: none;
    border-radius: var(--smtc-corner-ctrl-rest);
    box-shadow: inset 0 0 0 var(--smtc-ctrl-input-stroke-width-rest, var(--smtc-stroke-width-default)) var(--smtc-ctrl-input-stroke-rest, var(--smtc-stroke-ctrl-on-outline-rest));
    box-sizing: border-box;
    color: var(--smtc-foreground-ctrl-neutral-primary-rest);
    column-gap: var(--smtc-gap-inside-ctrl-default);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: space-between;
    font-family: var(--smtc-text-style-default-regular-font-family);
    font-size: var(--smtc-text-ramp-item-body-font-size, var(--smtc-text-global-body3-font-size));
    font-weight: var(--smtc-text-style-default-regular-weight);
    line-height: var(--smtc-text-ramp-item-body-line-height, var(--smtc-text-global-body3-line-height));
    min-width: 160px;
    overflow: hidden;
    padding: 0 var(--smtc-padding-ctrl-horizontal-default);
    position: relative;
    text-align: start;
    width: 100%;
    transition-property: background-color, color;
    transition-duration: 150ms;
}

/* Bottom line — rest */
.sr-select-trigger::before,
.sr-select-trigger::after {
    content: '';
    position: absolute;
    inset: auto 0 0;
    pointer-events: none;
}

.sr-select-trigger::before {
    height: var(--smtc-ctrl-input-bottom-line-stroke-width-rest, var(--smtc-stroke-width-default));
    background-color: var(--smtc-ctrl-input-bottom-line-stroke-rest, var(--smtc-foreground-ctrl-neutral-secondary-rest));
}

.sr-select-trigger::after {
    background-color: var(--smtc-ctrl-input-bottom-line-stroke-selected, var(--smtc-background-ctrl-brand-rest));
    height: var(--smtc-ctrl-input-bottom-line-stroke-width-selected);
    scale: 0 1;
    transition: scale 150ms cubic-bezier(0, 0, 0, 1);
}

/* Focus ring */
.sr-select-trigger:focus {
    outline: none;
}

.sr-select-trigger:focus-visible {
    box-shadow: inset 0 0 0 var(--smtc-ctrl-focus-inner-stroke-width, var(--smtc-stroke-width-default)) var(--smtc-ctrl-focus-inner-stroke);
    outline: var(--smtc-ctrl-focus-outer-stroke-width) solid var(--smtc-ctrl-focus-outer-stroke, var(--smtc-background-ctrl-brand-rest));
}


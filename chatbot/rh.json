.sr-select-trigger:hover {
    background-color: var(--smtc-ctrl-input-background-hover, var(--smtc-background-ctrl-neutral-hover));
    color: var(--smtc-foreground-ctrl-neutral-primary-hover, var(--smtc-foreground-ctrl-neutral-primary-rest));

.sr-checkbox-indicator {
    display: flex;
    aspect-ratio: 1;
    width: var(--smtc-ctrl-choice-base-size, var(--smtc-size-ctrl-icon));
    height: var(--smtc-ctrl-choice-base-size, var(--smtc-size-ctrl-icon));

.sr-card {
    position: relative;
    box-sizing: border-box;
    background: var(--smtc-background-card-on-primary-default-rest);
    border-radius: var(--smtc-corner-card-rest);
    overflow: hidden;
    --_squircle-modifier: 1;
    corner-shape: squircle;
}

.bg-foreground-700 { background-color: currentcolor; }
h1,h2,h3,h4,h5,h6 { margin-block: 0; }

.sr-card-stroke {
    border: 1px solid var(--smtc-stroke-card-on-primary-rest, var(--smtc-null-color));
    box-shadow: var(--smtc-shadow-card-rest-key), var(--smtc-shadow-card-rest-ambient);
}

.sr-card-sm {
    border-radius: calc(var(--smtc-corner-card-rest) * var(--_squircle-modifier));
}

.sr-card-md {
    border-radius: calc(var(--smtc-corner-card-rest) * var(--_squircle-modifier));
}

.sr-card-lg {
    border-radius: calc(var(--smtc-corner-card-rest) * var(--_squircle-modifier));;
}
@supports (corner-shape: squircle) {
      :host {
        --_squircle-modifier: 1.8;
      }
    }
</style><style data-sr-styles="genui-card">
/* Card size constraints */

.genui-card-container {
    display: flex;
    height: 100%;
    flex-direction: row;
    align-items: stretch;
    justify-content: stretch;
    overflow: hidden;
}

.genui-card-sm {
    min-width: 224px;
    max-width: 320px;
}

.genui-card-md {
    min-width: 320px;
    max-width: 540px;
}

.genui-card-lg {
    min-width: 320px;
    max-width: 720px;
}

.genui-card-full {
    width: 100%;
}
</style><style data-sr-styles="genui-list-view-item">

/* Base */

.sr-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    box-sizing: border-box;
    border: none;
    cursor: pointer;
    font-family: var(--smtc-text-style-default-regular-font-family);
    font-weight: var(--smtc-text-ctrl-button-weight-default, var(--smtc-text-style-default-regular-weight));
    text-align: center;
    text-decoration-line: none;
    user-select: none;
    outline-width: 2px;
    outline-offset: 1px;
    box-shadow: var(--mai-smtc-shadow-ctrl-neutral-inner-shine) inset, var(--mai-smtc-shadow-ctrl-neutral-key), var(--mai-smtc-shadow-ctrl-neutral-contour);
    transition-duration: 100ms;
    transition-property: background, color;
    transition-timing-function: linear;
}

@media screen and (prefers-reduced-motion: reduce) {
    .sr-btn {
        transition-duration: 0.01ms;
    }
}

.sr-btn:focus-visible {
    outline-style: solid;
    outline-color: var(--smtc-ctrl-focus-outer-stroke, var(--smtc-background-ctrl-brand-rest));
}

/* Color variants */

/* -- default (neutral) */
.sr-btn-color-default {
    
    background-color: var(--smtc-background-ctrl-neutral-rest);
    color: var(--smtc-foreground-ctrl-neutral-primary-rest);
    border: var(--smtc-stroke-width-default) solid var(--smtc-stroke-ctrl-on-neutral-rest, var(--smtc-null-color));
    box-shadow: var(--mai-smtc-shadow-ctrl-neutral-inner-shine) inset, var(--mai-smtc-shadow-ctrl-neutral-key), var(--mai-smtc-shadow-ctrl-neutral-contour);

    fill: var(--smtc-foreground-ctrl-neutral-primary-rest);
}
.sr-btn-color-default:hover {
    
    background-color: var(--smtc-background-ctrl-neutral-hover);
    color: var(--smtc-foreground-ctrl-neutral-primary-hover, var(--smtc-foreground-ctrl-neutral-primary-rest));

}
.sr-btn-color-default:active {
    
    background-color: var(--smtc-background-ctrl-neutral-pressed);
    color: var(--smtc-foreground-ctrl-neutral-primary-pressed, var(--smtc-foreground-ctrl-neutral-primary-rest));

    fill: var(--smtc-foreground-ctrl-neutral-primary-pressed, var(--smtc-foreground-ctrl-neutral-primary-rest));

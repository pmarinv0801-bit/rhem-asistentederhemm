    border: var(--smtc-stroke-width-default) solid var(--smtc-null-color);
    box-sizing: border-box;
    color: var(--smtc-foreground-ctrl-on-subtle-rest, var(--smtc-foreground-ctrl-neutral-primary-rest));
    cursor: pointer;
    -webkit-tap-highlight-color: transparent;
}

.sr-dropdown-option:hover {
    background-color: var(--smtc-background-ctrl-subtle-hover);
